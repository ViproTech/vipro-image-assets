# WordPress Plugin .gitignore

# Build artifacts and distribution files
*.zip
/dist/
/build/
build/Release

# Node.js dependencies and cache
node_modules/
.npm
*.tgz

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development tools and scripts (specific to this plugin)

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment and config files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary and backup files
*.tmp
*.temp
*.bak
*.backup

# Testing and coverage
coverage
.eslintcache

# Composer (if ever used)
/vendor/
composer.phar

# Lock files (team decision - uncomment if you want to track them)
# package-lock.json
# yarn.lock